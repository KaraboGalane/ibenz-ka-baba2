# EmailJS configuration
# Create a free account at https://www.emailjs.com
# 1. Add an Email Service (e.g. Gmail) -> copy the Service ID
# 2. Create two Email Templates -> copy each Template ID
#    - one template for the booking notification sent to YOU (the owner)
#    - one template for the confirmation email sent to the CUSTOMER
# 3. Copy your Public Key from Account > API Keys

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_OWNER_TEMPLATE_ID=your_owner_template_id
VITE_EMAILJS_CUSTOMER_TEMPLATE_ID=your_customer_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Business contact details (used across the site)
VITE_OWNER_EMAIL=bookings@ibenzkababa.co.za
VITE_BUSINESS_PHONE=+27 00 000 0000
VITE_WHATSAPP_NUMBER=27000000000
VITE_BUSINESS_ADDRESS=Pretoria, Gauteng, South Africa

# Banking details shown in the customer confirmation email
VITE_BANK_NAME=Your Bank
VITE_BANK_ACCOUNT_HOLDER=iBenz ka Baba (Pty) Ltd
VITE_BANK_ACCOUNT_NUMBER=0000000000
VITE_BANK_BRANCH_CODE=000000
VITE_BANK_PROOF_OF_PAYMENT_EMAIL=payments@ibenzkababa.co.za
